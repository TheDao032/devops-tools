# Packer build outputs — never commit binaries
# (covers both legacy monolith output/<tenant>/... and two-stage output/base/...)
output/
*.box
*.ova
*.qcow2
*.vmdk
*.iso

# Packer state
.packer.d/
crash.log

# Cached plugin downloads
.packer_plugins/

# SSH keypair generated by scripts/build.sh — private key, NEVER commit.
# Public half is freely shareable but excluded too because it gets rendered
# into http/user-data on each build (recreatable from the .pub on disk).
keys/

# Rendered cloud-init seed — regenerated from http/user-data.tmpl by
# scripts/build.sh on every run. The .tmpl is the source of truth.
http/user-data

# Local smoke-test workspaces — ephemeral Vagrant state for box validation.
# Each subdir holds a Vagrantfile + .vagrant/ runtime state. Never committed.
smoke/
