stream {
    upstream k3s_servers {
        {% for server in servers %}
        server {{ server.ip }}:{{ server.port }};
        {% endfor %}
    }

    server {
        listen 6445;  # Change this to an available port
        proxy_pass k3s_servers;
        proxy_timeout 3s;
        proxy_connect_timeout 1s;
    }
}
