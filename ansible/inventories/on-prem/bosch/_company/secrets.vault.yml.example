# Encrypt this file with ansible-vault using the Bosch vault password:
#   ansible-vault encrypt secrets.vault.yml --vault-password-file ~/.config/ansible-vault/bosch
#
# Real file (without .example suffix) MUST be ansible-vault encrypted.
# Never commit the unencrypted form.
---
ansible_become_pass: "REPLACE_ME"
vault_root_token: "REPLACE_ME"
postgres_admin_password: "REPLACE_ME"
k3s_token: "REPLACE_ME"
ssh_private_key_bosch: |
  -----BEGIN OPENSSH PRIVATE KEY-----
  REPLACE_ME
  -----END OPENSSH PRIVATE KEY-----
